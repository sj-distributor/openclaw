{
  "name": "@sj-distributor/openclaw-omelink",
  "version": "2026.3.16",
  "description": "Omelink plugin for OpenClaw",
  "license": "MIT",
  "files": [
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "dependencies": {
    "openclaw": "^2026.3.11"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "omelink",
      "label": "Omelink",
      "selectionLabel": "Omelink",
      "docsPath": "/channels/omelink",
      "docsLabel": "omelink",
      "blurb": "Omelink messaging channel.",
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@sj-distributor/openclaw-omelink",
      "localPath": "extensions/omelink",
      "defaultChoice": "npm"
    }
  }
}
